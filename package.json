{
  "name": "my-harness",
  "version": "0.9.2",
  "description": "Personal Claude Code plugin for productivity enhancement",
  "type": "module",
  "main": "dist/mcp-server.js",
  "scripts": {
    "build": "tsc && node scripts/bundle-mcp.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "sync-version": "node scripts/sync-version.mjs",
    "version": "node scripts/sync-version.mjs && git add .claude-plugin/plugin.json .claude-plugin/marketplace.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "license": "MIT"
}
